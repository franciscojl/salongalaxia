                }
              }
            },
            ".content-head": {
              "max-width": "800px"
            },
            ".mbr-section-title": {
              "color": "#2af7f4"
            },
            ".card-title": {
              "color": "#2af7f4"
            },
            "P": {
              "color": "#ffffff"
            }
